usage() {
  cat <<'USAGE'
zebra-agent-onboarding [run|choose-primary] [--cwd <path>] [--agent <agent>] [--language <en|ja|ko>] [--continue-with-command-file <path>]
zebra-agent-onboarding mark-ready --agent <agent> --run-id <runId> [--language <en|ja|ko>]

Commands:
  run             Scan supported CLIs, choose/install a primary agent, then launch it.
  choose-primary  Force a primary-agent choice even if a saved preference exists.
                  Pass --agent to recover or install a specific selected agent.
  mark-ready      Compatibility write path; normal flow completes via readiness probes.

Options:
  --continue-with-command-file <path>
                  After primary-agent selection succeeds, run this command file
                  in the same terminal instead of launching the bare provider CLI.

Supported agents:
  claude, codex, antigravity

State:
  ~/Library/Application Support/zebra/onboarding/agent-cli-state.json
  ~/Library/Application Support/zebra/onboarding/agent-cli-events.jsonl
  ~/Library/Application Support/zebra/agent/preferences.json
USAGE
}

normalize_language() {
  local raw lower
  raw="${1:-}"
  lower="$(printf '%s' "$raw" | tr '[:upper:]_' '[:lower:]-')"
  case "$lower" in
    ko|ko-*) printf 'ko' ;;
    ja|ja-*) printf 'ja' ;;
    en|en-*) printf 'en' ;;
    *) return 1 ;;
  esac
}

detect_system_language() {
  local raw
  raw="$(defaults read -g AppleLanguages 2>/dev/null | awk -F'"' '/"/ { print $2; exit }' || true)"
  normalize_language "$raw" 2>/dev/null || printf 'en'
}

set_onboarding_language() {
  local requested="${1:-${ONBOARDING_LANGUAGE:-}}"
  if ONBOARDING_LANGUAGE="$(normalize_language "$requested" 2>/dev/null)"; then
    export ZEBRA_ONBOARDING_LANGUAGE="$ONBOARDING_LANGUAGE"
    return
  fi
  ONBOARDING_LANGUAGE="$(detect_system_language)"
  export ZEBRA_ONBOARDING_LANGUAGE="$ONBOARDING_LANGUAGE"
}

language_argument() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --language)
        printf '%s\n' "${2:-}"
        return
        ;;
    esac
    shift
  done
}

