}

now_iso() {
  date -u '+%Y-%m-%dT%H:%M:%SZ'
}

new_run_id() {
  local random_hex
  random_hex="$(od -An -N2 -tx1 /dev/urandom 2>/dev/null | tr -d ' \n')"
  printf '%s-%s\n' "$(date -u '+%Y-%m-%dT%H-%M-%SZ')" "${random_hex:-$$}"
}

resolve_self_path() {
  local source_path dir
  source_path="${BASH_SOURCE[0]}"
  if [[ "$source_path" != /* ]]; then
    source_path="$(command -v -- "$source_path" 2>/dev/null || printf '%s/%s' "$PWD" "$source_path")"
  fi
  dir="$(cd "$(dirname "$source_path")" && pwd -P)"
  printf '%s/%s\n' "$dir" "$(basename "$source_path")"
}

json_string() {
  local value="$1"
  value="${value//\\/\\\\}"
  value="${value//\"/\\\"}"
  value="${value//$'\n'/\\n}"
  value="${value//$'\r'/\\r}"
  value="${value//$'\t'/\\t}"
  printf '"%s"' "$value"
}

json_nullable_string() {
  local value="${1:-}"
  if [[ -z "$value" ]]; then
    printf 'null'
  else
    json_string "$value"
  fi
}

json_string_array() {
  local first=1 item
  printf '['
  for item in "$@"; do
    if [[ "$first" -eq 0 ]]; then
      printf ','
    fi
    first=0
    json_string "$item"
  done
  printf ']'
}

valid_agent() {
  case "$1" in
    claude|codex|antigravity) return 0 ;;
    *) return 1 ;;
  esac
}

display_name() {
