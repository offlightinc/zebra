}

append_event() {
  local event="$1"
  local extra="${2:-}"
  mkdir -p "$ONBOARDING_DIR"
  {
    printf '{"ts":'
    json_string "$(now_iso)"
    printf ',"runId":'
    json_string "$RUN_ID"
    printf ',"event":'
    json_string "$event"
