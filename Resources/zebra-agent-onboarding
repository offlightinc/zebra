resolve_self_path() {
  local source_path dir
  source_path="${BASH_SOURCE[0]}"
  if [[ "$source_path" != /* ]]; then
    source_path="$(command -v -- "$source_path" 2>/dev/null || printf '%s/%s' "$PWD" "$source_path")"
  fi
  dir="$(cd "$(dirname "$source_path")" && pwd -P)"
  printf '%s/%s\n' "$dir" "$(basename "$source_path")"
}

json_string() {
  local value="$1"
  value="${value//\\/\\\\}"
  value="${value//\"/\\\"}"
  value="${value//$'\n'/\\n}"
  value="${value//$'\r'/\\r}"
  value="${value//$'\t'/\\t}"
  printf '"%s"' "$value"
}

json_nullable_string() {
  local value="${1:-}"
  if [[ -z "$value" ]]; then
    printf 'null'
  else
    json_string "$value"
  fi
}

json_string_array() {
  local first=1 item
  printf '['
  for item in "$@"; do
    if [[ "$first" -eq 0 ]]; then
      printf ','
    fi
    first=0
    json_string "$item"
  done
  printf ']'
}

json_raw_field() {
  local key="$1"
  local payload="$2"
  local tmp status
  tmp="$(mktemp "${TMPDIR:-/tmp}/zebra-json.XXXXXX")"
  printf '%s' "$payload" > "$tmp"
  plutil -extract "$key" raw -o - "$tmp" 2>/dev/null
  status="$?"
  rm -f "$tmp"
  return "$status"
}

json_bool_field_is_true() {
  local key="$1"
  local payload="$2"
  local value
  value="$(json_raw_field "$key" "$payload" 2>/dev/null | tr '[:upper:]' '[:lower:]')" || return 1
  case "$value" in
    true|1|yes) return 0 ;;
    *) return 1 ;;
  esac
}

