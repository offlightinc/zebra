install_codex_from_github_release() {
  local target archive_url tmpdir archive extracted install_path
  target="$(codex_standalone_target)" || return 1
  archive_url="https://github.com/openai/codex/releases/latest/download/codex-$target.tar.gz"
  tmpdir="$(mktemp -d "${TMPDIR:-/tmp}/zebra-codex-install.XXXXXX")" || return 1
  archive="$tmpdir/codex.tar.gz"
  install_path="$CODEX_INSTALL_BIN_DIR/codex"

  if ! curl -fL "$archive_url" -o "$archive"; then
    rm -rf "$tmpdir"
    return 1
  fi
  if ! tar -xzf "$archive" -C "$tmpdir"; then
    rm -rf "$tmpdir"
    return 1
  fi
  extracted="$tmpdir/codex-$target"
  if [[ ! -f "$extracted" ]]; then
    extracted=""
    for candidate in "$tmpdir"/codex*; do
      if [[ -f "$candidate" && -x "$candidate" ]]; then
        extracted="$candidate"
        break
      fi
    done
  fi
  if [[ -z "$extracted" || ! -f "$extracted" ]]; then
    rm -rf "$tmpdir"
    return 1
  fi

  mkdir -p "$(dirname "$install_path")"
  cp "$extracted" "$install_path"
  chmod +x "$install_path"
  rm -rf "$tmpdir"
}

path_writable_or_creatable() {
  local path="$1"
  local current="$path"
  while [[ ! -e "$current" ]]; do
    local parent
    parent="$(dirname "$current")"
    if [[ "$parent" == "$current" ]]; then
      return 1
    fi
    current="$parent"
  done
  [[ -w "$current" && -x "$current" ]]
}

npm_global_prefix() {
  npm config get prefix 2>/dev/null | sed -n '1{s/[[:space:]]*$//;p;q;}'
}

npm_prepend_prefix_bin() {
  local prefix="$1"
  [[ -n "$prefix" ]] || return 0
  export PATH="$prefix/bin:$PATH"
}

npm_prefix_supports_global_install() {
  local prefix="$1"
  [[ -n "$prefix" ]] || return 1
  path_writable_or_creatable "$prefix/bin" \
    && path_writable_or_creatable "$prefix/lib/node_modules"
}

configure_user_npm_global_prefix() {
  local prefix="$HOME/.local"
  msg install_npm_prefix_configuring
  mkdir -p "$prefix/bin" "$prefix/lib/node_modules"
  npm_prepend_prefix_bin "$prefix"
  npm config set prefix "$prefix"
}

prepare_npm_global_install() {
  local prefix
  prefix="$(npm_global_prefix || true)"
  if npm_prefix_supports_global_install "$prefix"; then
    npm_prepend_prefix_bin "$prefix"
    return 0
  fi
  configure_user_npm_global_prefix
}

install_claude_with_npm() {
  prepare_npm_global_install || return 1
  npm install -g @anthropic-ai/claude-code || return 1
  agent_is_available_to_zebra claude && return 0
  expose_hidden_agent_install claude
}

node_pkg_url_from_index() {
  local index version
  if [[ -n "$NODE_PKG_URL" ]]; then
    printf '%s\n' "$NODE_PKG_URL"
    return 0
  fi
  index="$(curl -fsSL https://nodejs.org/dist/index.json)" || return 1
  version="$(
    printf '%s' "$index" \
      | tr '{' '\n' \
      | awk '/"lts":("[^"]+"|true)/ {
          version = $0
          sub(/^.*"version"[[:space:]]*:[[:space:]]*"/, "", version)
          sub(/".*$/, "", version)
          if (version != $0 && version != "") {
            print version
            exit
          }
        }'
  )"
  [[ -n "$version" ]] || return 1
  printf 'https://nodejs.org/dist/%s/node-%s.pkg\n' "$version" "$version"
}

recover_node_with_official_pkg() {
  local pkg_url download_dir pkg_path
  pkg_url="$(node_pkg_url_from_index)" || return 1
  download_dir="$ONBOARDING_DIR/downloads"
  mkdir -p "$download_dir"
  pkg_path="$download_dir/node.pkg"
  curl -fL "$pkg_url" -o "$pkg_path" || return 1
  open "$pkg_path" || return 1
  msg install_claude_node_opened
  printf '\n'
  read -r _ || true
  msg install_claude_node_checking
  export PATH="$HOME/.local/bin:/usr/local/bin:/opt/homebrew/bin:$PATH"
  command -v node >/dev/null 2>&1 || return 1
  command -v npm >/dev/null 2>&1 || return 1
  node --version >/dev/null 2>&1 || return 1
  npm --version >/dev/null 2>&1 || return 1
}

agent_is_available_to_zebra() {
  local agent="$1"
  resolve_executable "$agent"
  [[ "$RESOLVE_STATUS" == "installed" && -n "$RESOLVE_PATH" ]]
}

hidden_agent_executable_candidates() {
  local agent="$1"
  local binary
  binary="$(binary_name "$agent")"
  case "$agent" in
    claude)
      printf '%s\n' \
        "$HOME/.claude/local/$binary" \
        "$HOME/.claude/bin/$binary" \
        "$HOME/.local/share/claude/$binary"
      ;;
    codex)
      printf '%s\n' \
        "$HOME/.codex/bin/$binary" \
        "$HOME/.local/share/codex/$binary"
      ;;
  esac
}

expose_hidden_agent_install() {
  local agent="$1"
  local binary source target
  binary="$(binary_name "$agent")"
  if [[ "$agent" == "codex" ]]; then
    target="$CODEX_INSTALL_BIN_DIR/$binary"
  else
    target="$HOME/.local/bin/$binary"
  fi
  while IFS= read -r source; do
    [[ -n "$source" && -x "$source" ]] || continue
    is_transient_path "$source" && continue
    if [[ "$agent" == "claude" ]] && is_cmux_claude_wrapper "$source"; then
      continue
    fi
    mkdir -p "$(dirname "$target")"
    if [[ "$source" != "$target" ]]; then
      ln -sf "$source" "$target"
    fi
    agent_is_available_to_zebra "$agent" && return 0
  done < <(hidden_agent_executable_candidates "$agent")
  return 1
}

run_claude_installer_chain() {
  set -o pipefail
  msg install_claude_try_official
  if curl -fsSL https://claude.ai/install.sh | bash; then
    if agent_is_available_to_zebra claude; then
      msg install_method_succeeded "$(display_name claude)" "official installer"
      return 0
    fi
    if expose_hidden_agent_install claude; then
      msg install_method_succeeded "$(display_name claude)" "official installer"
      return 0
    fi
  fi
  msg install_claude_official_failed

  if command -v npm >/dev/null 2>&1; then
    msg install_claude_try_npm
    if install_claude_with_npm; then
      msg install_method_succeeded "$(display_name claude)" "npm"
      return 0
    fi
    msg install_claude_npm_failed
  else
    msg install_claude_skip_npm
  fi

  if command -v brew >/dev/null 2>&1; then
    msg install_claude_try_brew
    if brew install --cask claude-code; then
      if agent_is_available_to_zebra claude; then
        msg install_method_succeeded "$(display_name claude)" "Homebrew"
        return 0
      fi
      if expose_hidden_agent_install claude; then
        msg install_method_succeeded "$(display_name claude)" "Homebrew"
        return 0
      fi
    fi
    msg install_claude_brew_failed
  else
    msg install_claude_skip_brew
  fi

  msg install_claude_need_node
  if recover_node_with_official_pkg; then
    msg install_claude_node_verified
    if install_claude_with_npm; then
      msg install_method_succeeded "$(display_name claude)" "npm"
      return 0
    fi
    msg install_claude_npm_failed
  else
    msg install_claude_node_failed
  fi
  return 1
}

run_codex_official_installer() {
  local tmpdir script output status
  tmpdir="$(mktemp -d "${TMPDIR:-/tmp}/zebra-codex-official.XXXXXX")" || return 1
  script="$tmpdir/install.sh"
  if ! curl -fsSL https://chatgpt.com/codex/install.sh -o "$script"; then
    rm -rf "$tmpdir"
    return 1
  fi
  chmod +x "$script" 2>/dev/null || true
  set +e
  output="$(CODEX_NON_INTERACTIVE=1 sh "$script" 2>&1)"
  status="$?"
  set -e
  rm -rf "$tmpdir"
  printf '%s\n' "$output" | sed '/^Start Codex now[?] \[y\/N\]/d'
  return "$status"
}

run_codex_installer_chain() {
  set -o pipefail
  if [[ "$FORCE_CODEX_OFFICIAL_INSTALLER_FAILURE" == "1" ]]; then
    msg install_codex_skip_official
  else
    msg install_codex_try_official
    if run_codex_official_installer; then
      if agent_is_available_to_zebra codex; then
        msg install_codex_method_succeeded "official installer"
        return 0
      fi
      if expose_hidden_agent_install codex; then
        msg install_codex_method_succeeded "official installer"
        return 0
      fi
    fi
    msg install_codex_official_failed
  fi

  if command -v npm >/dev/null 2>&1; then
    msg install_codex_try_npm
    if npm install -g @openai/codex; then
      if agent_is_available_to_zebra codex; then
        msg install_codex_method_succeeded "npm"
        return 0
      fi
    fi
    msg install_codex_npm_failed
  else
    msg install_codex_skip_npm
  fi

  if command -v brew >/dev/null 2>&1; then
    msg install_codex_try_brew
    if brew install --cask codex; then
      if agent_is_available_to_zebra codex; then
        msg install_codex_method_succeeded "Homebrew"
        return 0
      fi
    fi
    msg install_codex_brew_failed
  else
    msg install_codex_skip_brew
  fi

  msg install_codex_try_standalone
  if install_codex_from_github_release && agent_is_available_to_zebra codex; then
    msg install_codex_method_succeeded "standalone"
    return 0
  fi
  return 1
}

shell_single_quote() {
  printf "'"
  printf '%s' "$1" | sed "s/'/'\\\\''/g"
  printf "'"
}

path_dir_seen() {
  local needle="$1"
  shift || true
  local item
  for item in "$@"; do
    [[ "$item" == "$needle" ]] && return 0
  done
  return 1
}

agent_shell_path_dirs() {
  local agent="$1"
  local executable_path executable_dir
  local dirs=()
  executable_path="$(path_for_agent "$agent")"
  if [[ -n "$executable_path" ]]; then
    executable_dir="$(cd "$(dirname "$executable_path")" 2>/dev/null && pwd || true)"
    if [[ -n "$executable_dir" ]]; then
      dirs+=("$executable_dir")
    fi
  fi
  if [[ "$agent" == "codex" ]]; then
    dirs+=("$CODEX_INSTALL_BIN_DIR")
  fi
  dirs+=("$HOME/.local/bin")
  if [[ "$INCLUDE_GLOBAL_AGENT_PATHS" != "0" ]]; then
    dirs+=("/opt/homebrew/bin" "/usr/local/bin")
  fi

  local seen=()
  local dir
  for dir in "${dirs[@]}"; do
    [[ -n "$dir" ]] || continue
    if [[ "${#seen[@]}" -gt 0 ]] && path_dir_seen "$dir" "${seen[@]}"; then
      continue
    fi
    seen+=("$dir")
    printf '%s\n' "$dir"
  done
}

write_managed_block() {
  local file="$1"
  local block="$2"
  local tmp
  mkdir -p "$(dirname "$file")"
  tmp="$(mktemp "$file.tmp.XXXXXX")"
  if [[ -f "$file" ]]; then
    awk '
      $0 == "# >>> Zebra agent CLI PATH >>>" { skip = 1; next }
      $0 == "# <<< Zebra agent CLI PATH <<<" { skip = 0; next }
      skip != 1 { print }
    ' "$file" > "$tmp"
  else
    : > "$tmp"
  fi
  if [[ -s "$tmp" ]]; then
    printf '\n' >> "$tmp"
  fi
  printf '%s\n' "$block" >> "$tmp"
  mv "$tmp" "$file"
}

agent_shell_path_sh_block() {
  local dir quoted
  printf '# >>> Zebra agent CLI PATH >>>\n'
  while IFS= read -r dir; do
    [[ -n "$dir" ]] || continue
    quoted="$(shell_single_quote "$dir")"
    printf 'zebra_agent_cli_path_dir=%s\n' "$quoted"
    printf 'case ":$PATH:" in\n'
    printf '  *":$zebra_agent_cli_path_dir:"*) ;;\n'
    printf '  *) export PATH="$zebra_agent_cli_path_dir:$PATH" ;;\n'
    printf 'esac\n'
  done
  printf 'unset zebra_agent_cli_path_dir\n'
  printf '# <<< Zebra agent CLI PATH <<<'
}

agent_shell_path_fish_block() {
  local dir quoted
  printf '# >>> Zebra agent CLI PATH >>>\n'
  while IFS= read -r dir; do
    [[ -n "$dir" ]] || continue
    quoted="$(shell_single_quote "$dir")"
    printf 'if not contains -- %s $PATH\n' "$quoted"
    printf '    set -gx PATH %s $PATH\n' "$quoted"
    printf 'end\n'
  done
  printf '# <<< Zebra agent CLI PATH <<<'
}

configure_shell_path_for_agent() {
  local agent="$1"
  local sh_block fish_block extra
  [[ "$CONFIGURE_SHELL_PATH" != "0" ]] || return 0
  sh_block="$(agent_shell_path_dirs "$agent" | agent_shell_path_sh_block)"
  fish_block="$(agent_shell_path_dirs "$agent" | agent_shell_path_fish_block)"

  write_managed_block "$HOME/.zprofile" "$sh_block"
  write_managed_block "$HOME/.zshrc" "$sh_block"
  write_managed_block "$HOME/.bash_profile" "$sh_block"
  write_managed_block "$HOME/.bashrc" "$sh_block"
  write_managed_block "$HOME/.config/fish/conf.d/zebra-agent-path.fish" "$fish_block"

  extra=',"agent":'
  extra+="$(json_string "$agent")"
  append_event shell_path_configured "$extra"
  msg install_shell_path_configured "$(binary_name "$agent")"
}

mkdirs() {
  mkdir -p "$ONBOARDING_DIR" "$AGENT_DIR"
}

append_event() {
  local event="$1"
  local extra="${2:-}"
  mkdir -p "$ONBOARDING_DIR"
  {
    printf '{"ts":'
    json_string "$(now_iso)"
    printf ',"runId":'
    json_string "$RUN_ID"
    printf ',"event":'
    json_string "$event"
    printf '%s}\n' "$extra"
  } >> "$EVENTS_FILE"
}

clear_state_error() {
  STATE_ERROR_CODE=""
  STATE_ERROR_AGENT=""
  STATE_ERROR_MESSAGE=""
  STATE_ERROR_RECOVERABLE="true"
}

set_state_error() {
  STATE_ERROR_CODE="$1"
  STATE_ERROR_AGENT="$2"
  STATE_ERROR_MESSAGE="$3"
  STATE_ERROR_RECOVERABLE="${4:-true}"
}

state_error_json() {
  if [[ -z "$STATE_ERROR_CODE" ]]; then
    printf 'null'
    return
  fi
  printf '{"code":'
  json_string "$STATE_ERROR_CODE"
  printf ',"agent":'
  json_nullable_string "$STATE_ERROR_AGENT"
  printf ',"message":'
  json_string "$STATE_ERROR_MESSAGE"
  printf ',"recoverable":%s}' "$STATE_ERROR_RECOVERABLE"
}

write_candidates_json() {
  local first=1 i terminal_launchable path version
  printf '['
  for i in "${!CANDIDATE_IDS[@]}"; do
    if [[ "$first" -eq 0 ]]; then
      printf ','
    fi
    first=0
    if [[ "${CANDIDATE_INSTALL_STATES[$i]}" == "installed" ]]; then
      terminal_launchable=true
    else
      terminal_launchable=false
    fi
    path="${CANDIDATE_PATHS[$i]}"
    version="${CANDIDATE_VERSIONS[$i]}"
    printf '\n    {'
    printf '\n      "id":'
    json_string "${CANDIDATE_IDS[$i]}"
    printf ',\n      "displayName":'
    json_string "${CANDIDATE_DISPLAY_NAMES[$i]}"
    printf ',\n      "binaryName":'
    json_string "${CANDIDATE_BINARY_NAMES[$i]}"
    printf ',\n      "executablePath":'
    json_nullable_string "$path"
    printf ',\n      "version":'
    json_nullable_string "$version"
    printf ',\n      "installState":'
    json_string "${CANDIDATE_INSTALL_STATES[$i]}"
    printf ',\n      "authState":'
    json_string "${CANDIDATE_AUTH_STATES[$i]}"
    printf ',\n      "terminalLaunchable":%s' "$terminal_launchable"
    printf ',\n      "recommendedAction":'
    json_string "${CANDIDATE_RECOMMENDED_ACTIONS[$i]}"
    printf '\n    }'
  done
  if [[ "${#CANDIDATE_IDS[@]}" -gt 0 ]]; then
    printf '\n  '
  fi
  printf ']'
}

write_state() {
  local phase="$1"
  local selected_agent="${2:-$SELECTED_AGENT}"
  local tmp
  mkdir -p "$ONBOARDING_DIR"
  tmp="$(mktemp "$STATE_FILE.tmp.XXXXXX")"
  {
    printf '{\n'
    printf '  "schemaVersion": %s,\n' "$STATE_SCHEMA_VERSION"
    printf '  "runId": '
    json_string "$RUN_ID"
    printf ',\n  "phase": '
    json_string "$phase"
    printf ',\n  "updatedAt": '
    json_string "$(now_iso)"
    printf ',\n  "savedPrimary": '
    json_nullable_string "$SAVED_PRIMARY"
    printf ',\n  "selectedAgent": '
    json_nullable_string "$selected_agent"
    printf ',\n  "candidates": '
    write_candidates_json
    printf ',\n  "error": '
    state_error_json
    printf '\n}\n'
  } > "$tmp"
  mv "$tmp" "$STATE_FILE"
}

read_plist_raw_key() {
  local file="$1"
  local key="$2"
  [[ -f "$file" ]] || return 1
  plutil -extract "$key" raw -o - "$file" 2>/dev/null || return 1
}

load_existing_state() {
  local selected_agent
  STATE_PHASE=""
  STATE_RUN_ID=""
  STATE_SELECTED_AGENT=""
  [[ -f "$STATE_FILE" ]] || return 1

  STATE_PHASE="$(read_plist_raw_key "$STATE_FILE" phase || true)"
  STATE_RUN_ID="$(read_plist_raw_key "$STATE_FILE" runId || true)"
  selected_agent="$(read_plist_raw_key "$STATE_FILE" selectedAgent || true)"
  if valid_agent "$selected_agent"; then
    STATE_SELECTED_AGENT="$selected_agent"
  fi
}

append_resume_event() {
  local phase="$1"
  local agent="${2:-}"
  local extra
  extra=',"phase":'
  extra+="$(json_string "$phase")"
  if valid_agent "$agent"; then
    extra+=',"agent":'
    extra+="$(json_string "$agent")"
  fi
  append_event agent_onboarding_resumed "$extra"
}

scan_agents_for_resume() {
