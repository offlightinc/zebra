#!/usr/bin/env bash
# zebra-brain-sync
#
# Generic per-vault git sync. Phases:
#   lock -> fetch -> validate -> commit -> pull --rebase -> push -> gbrain ping
#
# Emitted on stderr first line of every fail: `[REASON:<id>] <message>` where
# <id> ∈ authExpired|offline|pushRejected|permissionDenied|diskFull|hookFailed|rateLimit|conflict|notGbrainRepo|alreadyRunning|unknown.
# Zebra's `BrainSyncService` parses the tag to classify the FailureReason.
#
# Originates from the brain-offlight `local-offlight-brain-sync`,
# generic-fied here (no brand-bound repo basename / remote URL / gbrain CLI
# path checks). That source script remains in the brain repo and is not
# touched by zebra.

set -euo pipefail

usage() {
  cat <<'USAGE'
zebra-brain-sync --repo <path> [--no-ping] [--dry-run]

Options:
  --repo <path>   Required. Path to the brain git repo to sync.
  --no-ping       Skip `gbrain remote ping` after a successful push.
  --dry-run       Validate and print what would happen, without changing git state.
  --help          Show this help.

Environment:
  ZEBRA_SYNC_COMMIT_MSG   Override commit message. Must include Slack-Summary.
USAGE
}

DRY_RUN=0
PING=1
REPO_ROOT=""

# user shell PATH 의 일부 (zebra 가 Process 환경에 보강하지만 안전망).
export PATH="$HOME/.bun/bin:$HOME/.local/bin:/opt/homebrew/bin:/usr/local/bin:$PATH"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --repo)
      REPO_ROOT="${2:-}"
      shift 2
      ;;
    --no-ping)
      PING=0
      shift
      ;;
    --dry-run)
      DRY_RUN=1
      shift
      ;;
    --help|-h)
      usage
      exit 0
      ;;
    *)
      printf 'unknown option: %s\n\n' "$1" >&2
      usage >&2
      exit 2
      ;;
  esac
done

log() {
  printf '[zebra-brain-sync] %s\n' "$*"
}

# fail "<reason_id>" "<human message>"
# zebra 가 stderr 첫 줄의 [REASON:<id>] 태그를 파싱해서 FailureReason enum 으로 변환.
fail() {
  local reason="$1"
  shift
  printf '[REASON:%s] %s\n' "$reason" "$*" >&2
  exit 1
}

stat_mtime_epoch() {
  local path="$1"
  if mtime="$(stat -f '%m' "$path" 2>/dev/null)"; then
    printf '%s\n' "$mtime"
    return 0
  fi
  stat -c '%Y' "$path" 2>/dev/null || printf '0\n'
}

lock_age_seconds() {
  local path="$1"
  local now mtime
  now="$(date +%s)"
  mtime="$(stat_mtime_epoch "$path")"
  if [[ "$mtime" =~ ^[0-9]+$ ]] && [[ "$now" =~ ^[0-9]+$ ]] && (( now >= mtime )); then
    printf '%s\n' "$((now - mtime))"
  else
    printf '0\n'
  fi
}

read_lock_value() {
  local key="$1"
  local file="$2"
  [[ -f "$file" ]] || return 1
  awk -F= -v key="$key" '$1 == key { print substr($0, length(key) + 2); exit }' "$file"
}

process_command() {
  local pid="$1"
  ps -p "$pid" -o command= 2>/dev/null || true
}

is_zebra_sync_process() {
  local pid="$1"
  local command
  [[ "$pid" =~ ^[0-9]+$ ]] || return 1
  kill -0 "$pid" 2>/dev/null || return 1
  command="$(process_command "$pid")"
  [[ -z "$command" || "$command" == *"zebra-brain-sync"* ]]
}

write_lock_owner() {
  local owner_file="$1"
  {
    printf 'pid=%s\n' "$$"
    printf 'started_at=%s\n' "$(date -u '+%Y-%m-%dT%H:%M:%SZ')"
    printf 'repo=%s\n' "$REPO_ROOT"
    printf 'host=%s\n' "$(hostname 2>/dev/null || printf unknown)"
  } > "$owner_file"
}

lock_detail() {
  local lock_dir="$1"
  local owner_file="$lock_dir/owner"
  local age pid started_at repo host command
  age="$(lock_age_seconds "$lock_dir")"
  pid="$(read_lock_value pid "$owner_file" 2>/dev/null || true)"
  started_at="$(read_lock_value started_at "$owner_file" 2>/dev/null || true)"
  repo="$(read_lock_value repo "$owner_file" 2>/dev/null || true)"
  host="$(read_lock_value host "$owner_file" 2>/dev/null || true)"
  command=""
  if [[ "$pid" =~ ^[0-9]+$ ]]; then
    command="$(process_command "$pid")"
  fi
  printf 'lock=%s age=%ss pid=%s started_at=%s host=%s repo=%s command=%s' \
    "$lock_dir" "$age" "${pid:-unknown}" "${started_at:-unknown}" "${host:-unknown}" "${repo:-unknown}" "${command:-unknown}"
}

[[ -n "$REPO_ROOT" ]] || fail "hookFailed" "missing --repo <path>"
[[ -d "$REPO_ROOT" ]] || fail "hookFailed" "repo path does not exist: $REPO_ROOT"
[[ -d "$REPO_ROOT/.git" ]] || fail "hookFailed" "not a git repo: $REPO_ROOT"

cd "$REPO_ROOT"

# Require an explicit GBrain routing marker at the selected vault root. Do not
# walk ancestors here: sync mutates and pushes this repo, so an unrelated git
# repo under a mounted parent directory must not inherit the parent's marker.
if [[ ! -f ".gbrain-mount" && ! -f ".gbrain-source" ]]; then
  fail "notGbrainRepo" "not a GBrain repo: missing .gbrain-mount or .gbrain-source at repo root"
fi

remote="${ZEBRA_SYNC_REMOTE:-origin}"

current_branch="$(git symbolic-ref --short HEAD 2>/dev/null || true)"
[[ -n "$current_branch" ]] || fail "hookFailed" "detached HEAD; refusing to sync"

branch="${ZEBRA_SYNC_BRANCH:-$current_branch}"
[[ "$current_branch" == "$branch" ]] || fail "hookFailed" "expected branch $branch, got $current_branch"

remote_url="$(git remote get-url "$remote" 2>/dev/null || true)"
[[ -n "$remote_url" ]] || fail "hookFailed" "missing git remote: $remote"

git_dir="$(git rev-parse --git-dir)"
for state_dir in rebase-merge rebase-apply MERGE_HEAD CHERRY_PICK_HEAD REVERT_HEAD; do
  [[ ! -e "$git_dir/$state_dir" ]] || fail "hookFailed" "git operation in progress ($state_dir); resolve it first"
done

lock_key="$(printf '%s' "$REPO_ROOT" | cksum | awk '{print $1}')"
lock_dir="${TMPDIR:-/tmp}/zebra-brain-sync.${lock_key}.lock"
lock_owner_file="$lock_dir/owner"
lock_stale_seconds="${ZEBRA_SYNC_LOCK_STALE_SECONDS:-1800}"
if ! mkdir "$lock_dir" 2>/dev/null; then
  lock_age="$(lock_age_seconds "$lock_dir")"
  lock_pid="$(read_lock_value pid "$lock_owner_file" 2>/dev/null || true)"
  if [[ "$lock_pid" =~ ^[0-9]+$ ]] && is_zebra_sync_process "$lock_pid"; then
    fail "alreadyRunning" "brain sync already running: $(lock_detail "$lock_dir")"
  fi

  if [[ ! "$lock_age" =~ ^[0-9]+$ ]]; then
    lock_age=0
  fi
  if [[ "$lock_pid" =~ ^[0-9]+$ ]] || (( lock_age >= lock_stale_seconds )); then
    log "removing stale brain sync lock: $(lock_detail "$lock_dir")"
    rm -rf "$lock_dir"
    if ! mkdir "$lock_dir" 2>/dev/null; then
      fail "alreadyRunning" "brain sync lock still exists after stale cleanup: $(lock_detail "$lock_dir")"
    fi
  else
    fail "alreadyRunning" "brain sync lock exists without owner metadata: $(lock_detail "$lock_dir")"
  fi
fi
write_lock_owner "$lock_owner_file"
trap 'rm -rf "$lock_dir"' EXIT

tmp_dir="$(mktemp -d "${TMPDIR:-/tmp}/zebra-brain-sync.XXXXXX")"
trap 'rm -rf "$tmp_dir"; rm -rf "$lock_dir"' EXIT
tracked_changes="$tmp_dir/tracked.z"
untracked_changes="$tmp_dir/untracked.z"

release_sync_lock() {
  rm -rf "$lock_dir"
  trap 'rm -rf "$tmp_dir"' EXIT
}

has_nul_records() {
  [[ -s "$1" ]]
}

print_nul_records() {
  while IFS= read -r -d '' path; do
    printf '  %s\n' "$path"
  done < "$1"
}

is_allowed_hidden_path() {
  local path="$1"

  # GBrain adapter skills are installed into a hidden adapter-owned directory
  # inside the brain repo. Keep the exception narrow so arbitrary dotfiles still
  # cannot be auto-committed by background sync.
  [[ "$path" == .gbrain-adapter/skills/*/SKILL.md ]]
}

# 14 self-validation checks below. 13 of them → hookFailed reason. The lone
# exception `conflict markers found` → conflict reason (it's the residue of an
# external git merge that produced markers in a .md file).
validate_path() {
  local path="$1"

  [[ -n "$path" ]] || fail "hookFailed" "empty git path"
  [[ "$path" != /* ]] || fail "hookFailed" "absolute path is not allowed: $path"
  [[ "$path" != *".."* ]] || fail "hookFailed" "path traversal is not allowed: $path"
  [[ "$path" != .* ]] || is_allowed_hidden_path "$path" || fail "hookFailed" "hidden files are not auto-committed: $path"
  [[ "$path" != ".git/"* ]] || fail "hookFailed" "git internals are not allowed: $path"
  [[ "$path" != ".gbrain/"* ]] || fail "hookFailed" "local gbrain state is not allowed: $path"
  [[ "$path" != "supabase/.temp/"* ]] || fail "hookFailed" "supabase temp state is not allowed: $path"
  [[ "$path" == *.md ]] || fail "hookFailed" "only markdown brain files are auto-committed: $path"

  if [[ -e "$path" ]]; then
    [[ -f "$path" ]] || fail "hookFailed" "not a regular file: $path"
    [[ ! -L "$path" ]] || fail "hookFailed" "symlinks are not auto-committed: $path"

    if grep -nE '^(<<<<<<<|=======|>>>>>>>)' "$path" >/dev/null; then
      fail "conflict" "conflict markers found in $path"
    fi

    if grep -nE '(gbrain_cs_[A-Za-z0-9]{16,}|postgres(ql)?://[^[:space:]]+:[^[:space:]]+@|OPENAI_API_KEY=sk-[A-Za-z0-9_-]{16,}|ANTHROPIC_API_KEY=sk-ant-[A-Za-z0-9_-]{16,}|GBRAIN_REMOTE_CLIENT_SECRET=[^<[:space:]]+)' "$path" >/dev/null; then
      fail "hookFailed" "possible secret found in $path"
    fi
  fi
}

validate_file_list() {
  local list_file="$1"
  while IFS= read -r -d '' path; do
    validate_path "$path"
  done < "$list_file"
}

frontmatter_title() {
  local path="$1"
  awk '
    BEGIN { in_frontmatter = 0 }
    NR == 1 && $0 == "---" { in_frontmatter = 1; next }
    in_frontmatter && $0 == "---" { exit }
    in_frontmatter && /^title:[[:space:]]*/ {
      sub(/^title:[[:space:]]*/, "")
      gsub(/^"|"$/, "")
      print
      exit
    }
  ' "$path"
}

staged_field_change() {
  local path="$1"
  local field="$2"
  local old_value new_value

  old_value="$(git diff --cached --unified=0 -- "$path" | awk -v field="$field" '
    $0 ~ "^-" field ":" {
      sub("^-" field ":[[:space:]]*", "")
      print
      exit
    }
  ')"
  new_value="$(git diff --cached --unified=0 -- "$path" | awk -v field="$field" '
    $0 ~ "^\\+" field ":" {
      sub("^\\+" field ":[[:space:]]*", "")
      print
      exit
    }
  ')"

  if [[ -n "$old_value" && -n "$new_value" && "$old_value" != "$new_value" ]]; then
    printf '%s\t%s\t%s\n' "$field" "$old_value" "$new_value"
  fi
}

staged_timeline_additions() {
  local path="$1"
  git diff --cached --unified=0 -- "$path" \
    | awk '/^\+- \*\*[0-9]{4}-[0-9]{2}-[0-9]{2}\*\*/ { sub(/^\+/, ""); print; count += 1 } count == 2 { exit }'
}

truncate_text() {
  local text="$1"
  local max="${2:-180}"
  if [[ "${#text}" -gt "$max" ]]; then
    printf '%s...\n' "${text:0:max}"
  else
    printf '%s\n' "$text"
  fi
}

strip_source_suffix() {
  local text="$1"
  text="${text%% [[]Source:*}"
  printf '%s\n' "$text"
}

clean_added_line() {
  local line="$1"
  line="${line#+}"
  line="${line#- }"
  line="${line### }"
  line="${line## }"
  line="${line#> }"
  printf '%s\n' "$line"
}

staged_first_meaningful_addition() {
  local path="$1"
  git diff --cached --unified=0 -- "$path" \
    | awk '
      /^\+\+\+/ { next }
      /^\+---$/ { next }
      /^\+[[:space:]]*$/ { next }
      /^\+(title|type|status|priority|owner|created|updated|tags|related|goal):/ { next }
      /^\+/ {
        sub(/^\+/, "")
        print
        exit
      }
    '
}

display_title_for_path() {
  local path="$1"
  local title=""
  if [[ -f "$path" ]]; then
    title="$(frontmatter_title "$path")"
  fi
  if [[ -n "$title" ]]; then
    printf '%s\n' "$title"
  else
    printf '%s\n' "$path"
  fi
}

write_generated_commit_message() {
  local message_file="$1"
  local staged_file_list="$2"
  local changed_count=0
  local task_count=0
  local first_title=""
  local first_summary_sentence=""
  local first_task_title=""
  local first_task_status_old=""
  local first_task_status_new=""
  local first_task_priority_old=""
  local first_task_priority_new=""
  local path title field old_value new_value timeline_line added_line detail_text label
  local items_file details_file

  items_file="$tmp_dir/generated-commit-items.txt"
  details_file="$tmp_dir/generated-commit-details.txt"
  : > "$items_file"
  : > "$details_file"

  while IFS= read -r -d '' path; do
    changed_count=$((changed_count + 1))
    title="$(display_title_for_path "$path")"
    [[ -n "$first_title" ]] || first_title="$title"
    printf -- '- %s\n' "$title" >> "$items_file"

    if [[ "$path" == tasks/*.md ]]; then
      task_count=$((task_count + 1))
      [[ -n "$first_task_title" ]] || first_task_title="$title"
    fi

    while IFS=$'\t' read -r field old_value new_value; do
      [[ -n "$field" ]] || continue
      case "$field" in
        status) label="상태" ;;
        priority) label="우선순위" ;;
        owner) label="담당자" ;;
        waiting_on) label="대기 사유" ;;
        title) label="제목" ;;
        *) label="$field" ;;
      esac
      detail_text="${label}: ${old_value} -> ${new_value}"
      printf -- '- %s: %s\n' "$title" "$detail_text" >> "$details_file"
      [[ -n "$first_summary_sentence" ]] || first_summary_sentence="${title}의 ${label}를 업데이트했습니다."
      if [[ "$field" == "status" && -z "$first_task_status_old" ]]; then
        first_task_status_old="$old_value"
        first_task_status_new="$new_value"
      elif [[ "$field" == "priority" && -z "$first_task_priority_old" ]]; then
        first_task_priority_old="$old_value"
        first_task_priority_new="$new_value"
      fi
    done < <(
      staged_field_change "$path" status
      staged_field_change "$path" priority
      staged_field_change "$path" owner
      staged_field_change "$path" waiting_on
      staged_field_change "$path" title
    )

    while IFS= read -r timeline_line; do
      [[ -n "$timeline_line" ]] || continue
      timeline_line="${timeline_line#- }"
      timeline_line="$(strip_source_suffix "$timeline_line")"
      timeline_line="$(truncate_text "$timeline_line" 180)"
      detail_text="타임라인 추가: ${timeline_line}"
      printf -- '- %s: %s\n' "$title" "$detail_text" >> "$details_file"
      [[ -n "$first_summary_sentence" ]] || first_summary_sentence="${title}에 타임라인을 추가했습니다."
    done < <(staged_timeline_additions "$path")

    if [[ -z "$first_summary_sentence" ]]; then
      added_line="$(staged_first_meaningful_addition "$path")"
      if [[ -n "$added_line" ]]; then
        added_line="$(clean_added_line "$added_line")"
        added_line="$(strip_source_suffix "$added_line")"
        added_line="$(truncate_text "$added_line" 180)"
        detail_text="내용 추가: ${added_line}"
        printf -- '- %s: %s\n' "$title" "$detail_text" >> "$details_file"
        first_summary_sentence="${title}에 내용을 추가했습니다."
      fi
    fi
  done < "$staged_file_list"

  if [[ "$task_count" -eq 1 && -n "$first_task_status_old" ]]; then
    case "$first_task_status_new" in
      canceled) printf 'tasks: cancel %s\n\n' "$first_task_title" > "$message_file" ;;
      done|completed) printf 'tasks: complete %s\n\n' "$first_task_title" > "$message_file" ;;
      waiting) printf 'tasks: mark waiting %s\n\n' "$first_task_title" > "$message_file" ;;
      *) printf 'tasks: update status for %s\n\n' "$first_task_title" > "$message_file" ;;
    esac
    printf 'Slack-Summary: 태스크 상태가 `%s` -> `%s`로 변경되었습니다.\n\n' "$first_task_status_old" "$first_task_status_new" >> "$message_file"
  elif [[ "$task_count" -eq 1 && -n "$first_task_priority_old" ]]; then
    printf 'tasks: update priority for %s\n\n' "$first_task_title" > "$message_file"
    printf 'Slack-Summary: 태스크 우선순위가 `%s` -> `%s`로 변경되었습니다.\n\n' "$first_task_priority_old" "$first_task_priority_new" >> "$message_file"
  elif [[ "$changed_count" -eq 1 ]]; then
    printf 'brain: update %s\n\n' "$first_title" > "$message_file"
    if [[ -n "$first_summary_sentence" ]]; then
      printf 'Slack-Summary: %s\n\n' "$first_summary_sentence" >> "$message_file"
    else
      printf 'Slack-Summary: %s 문서를 업데이트했습니다.\n\n' "$first_title" >> "$message_file"
    fi
  else
    printf 'brain: update %s markdown file(s)\n\n' "$changed_count" > "$message_file"
    printf 'Slack-Summary: 브레인 문서 %s개를 업데이트했습니다.\n\n' "$changed_count" >> "$message_file"
  fi

  printf 'Changed items:\n' >> "$message_file"
  cat "$items_file" >> "$message_file"

  printf '\nDetails:\n' >> "$message_file"
  if [[ -s "$details_file" ]]; then
    cat "$details_file" >> "$message_file"
  else
    sed 's/$/ 문서를 업데이트함/' "$items_file" >> "$message_file"
  fi

  printf '\nGenerated by zebra-brain-sync.\n' >> "$message_file"
}

log "repo: $REPO_ROOT"
log "phase: fetch"
if [[ "$DRY_RUN" == "1" ]]; then
  log "dry run: would run git fetch $remote $branch"
else
  # git fetch failure (network / auth / 403 / etc) — emit stderr 그대로 + reason 분류는
  # zebra 측 패턴 매칭에 위임. (stderr 가 길어 reason 태그 안 박음. 사용 사례 적음.)
  if ! git fetch "$remote" "$branch" 2>&1; then
    fail "unknown" "git fetch failed (see stderr above for cause)"
  fi
fi

git update-index -q --refresh || true
git diff --name-only -z HEAD -- > "$tracked_changes"
git ls-files --others --exclude-standard -z > "$untracked_changes"

log "phase: validate"
if has_nul_records "$tracked_changes" || has_nul_records "$untracked_changes"; then
  validate_file_list "$tracked_changes"
  validate_file_list "$untracked_changes"
else
  log "no local markdown changes to commit"
fi

if [[ "$DRY_RUN" == "1" ]]; then
  if has_nul_records "$tracked_changes"; then
    log "dry run: tracked changes"
    print_nul_records "$tracked_changes"
  fi
  if has_nul_records "$untracked_changes"; then
    log "dry run: untracked changes"
    print_nul_records "$untracked_changes"
  fi
  log "dry run: would commit allowed changes, pull --rebase, push if ahead, and ping if pushed"
  exit 0
fi

log "phase: commit"
committed_sha=""
if has_nul_records "$tracked_changes" || has_nul_records "$untracked_changes"; then
  while IFS= read -r -d '' path; do
    git add -- "$path"
  done < "$tracked_changes"
  while IFS= read -r -d '' path; do
    git add -- "$path"
  done < "$untracked_changes"

  if git diff --cached --quiet --exit-code; then
    log "nothing staged after validation"
  else
    commit_msg_file="$tmp_dir/commit-message.txt"
    if [[ -n "${ZEBRA_SYNC_COMMIT_MSG:-}" ]]; then
      printf '%s\n' "$ZEBRA_SYNC_COMMIT_MSG" > "$commit_msg_file"
      if ! grep -q '^Slack-Summary:' "$commit_msg_file"; then
        fail "hookFailed" "ZEBRA_SYNC_COMMIT_MSG must include a Slack-Summary line"
      fi
    else
      staged_commit_files="$tmp_dir/staged-commit-files.z"
      git diff --cached --name-only -z -- > "$staged_commit_files"
      write_generated_commit_message "$commit_msg_file" "$staged_commit_files"
      log "commit message: generated from staged markdown diff"
    fi
    git commit -F "$commit_msg_file"
    committed_sha="$(git rev-parse --short HEAD)"
  fi
else
  log "nothing to commit"
fi

log "phase: pull --rebase"
if ! git pull --rebase "$remote" "$branch" 2>&1; then
  # pull --rebase 실패 = 대개 conflict. git status --porcelain 로 UU 마커 확인.
  if git status --porcelain 2>/dev/null | grep -q '^UU'; then
    fail "conflict" "git pull --rebase produced conflicts; resolve in working tree"
  fi
  fail "unknown" "git pull --rebase failed (see stderr above for cause)"
fi

ahead_count="$(git rev-list --count "$remote/$branch"..HEAD 2>/dev/null || printf '0')"
if [[ "$ahead_count" =~ ^[0-9]+$ ]] && [[ "$ahead_count" -gt 0 ]]; then
  log "phase: push ($ahead_count commit(s) ahead)"
  if ! git push "$remote" "$branch" 2>&1; then
    # push stderr 의 reason 분류는 zebra 측 패턴 매칭에 위임.
    fail "unknown" "git push failed (see stderr above for cause)"
  fi
  pushed=1
else
  log "phase: push skipped; no local commits ahead"
  pushed=0
fi

# 마지막 정상 HEAD SHA 를 stdout 에 emit. zebra 가 `committed <sha>` 라인을 파싱해
# SyncState.synced 에 commit 으로 저장. push 했으면 그 SHA, 안 했으면 현재 HEAD.
final_sha="$(git rev-parse --short HEAD 2>/dev/null || true)"
if [[ -n "$final_sha" ]]; then
  printf 'committed %s\n' "$final_sha"
fi

release_sync_lock

if [[ "$pushed" == "1" && "$PING" == "1" ]]; then
  gbrain_cli="$(command -v gbrain || true)"
  if [[ -n "$gbrain_cli" ]]; then
    log "phase: remote ping"
    if ! "$gbrain_cli" remote ping --timeout "${ZEBRA_SYNC_PING_TIMEOUT:-5m}" 2>&1; then
      log "remote ping failed after push; GitHub is updated, Railway autopilot will pick it up"
    fi
  else
    log "remote ping skipped; gbrain CLI not found in PATH"
  fi
else
  log "phase: remote ping skipped"
fi

log "done"
